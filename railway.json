{
  "$schema": "https://railway.app/railway.schema.json",
  "projects": [
    {
      "name": "reelrwa-frontend",
      "build": {
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "nginx -g 'daemon off;'",
        "port": 8080
      }
    },
    {
      "name": "reelrwa-backend",
      "root": "backend",
      "build": {
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "node dist/main.js",
        "port": 3000
      }
    }
  ]
}
