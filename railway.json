{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "frontend",
      "build": {
        "dockerfile": "Dockerfile",
        "context": "."
      },
      "deploy": {
        "startCommand": "nginx -g 'daemon off;'",
        "ports": [
          {
            "port": 8080,
            "protocol": "http"
          }
        ]
      }
    },
    {
      "name": "backend",
      "build": {
        "dockerfile": "backend/Dockerfile",
        "context": "backend/.."
      },
      "deploy": {
        "startCommand": "node dist/main.js",
        "ports": [
          {
            "port": 3000,
            "protocol": "http"
          }
        ]
      }
    }
  ]
}
